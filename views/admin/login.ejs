<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <link rel="stylesheet" href="/styles/css/admin.css" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo+Narrow&family=Archivo&display=swap" rel="stylesheet">

  <title>RAT Supper Club - Admin Login</title>
  <link rel="icon" type="image/png" href="/images/logo.png">
</head>

<body>

<div class="login-page">
  <div class="login-card">

    <h1 class="login-title">RAT Admin</h1>

    <form method="POST" action="/admin/login" class="login-form">
      <input name="username" placeholder="Username" required />
      <input name="password" type="password" placeholder="Password" required />
      <button type="submit" class="login-button">Login</button>
    </form>

    <% if (error) { %>
      <p class="login-error">Invalid username or password</p>
    <% } %>

  </div>
</div>

</body>
</html>