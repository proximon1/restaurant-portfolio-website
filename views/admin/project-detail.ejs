<div class="admin-container">
  <h1 class="mb-4">
    <%= isNew ? "Create Project" : "Edit Project" %>
  </h1>

  <!-- PROJECT META -->
  <div class="project-card mb-4">
    <h3>Project details</h3>
    <p>
      <%= isNew ? 'Create a new project by providing project details and project items' : 'Edit the core information of the project, including its title and subtitle' %>
    </p>

    <form class="js-validate-form" action="<%= isNew ? '/admin/projects' : '/admin/projects/' + project.slug %>" method="POST">

      <div class="form-group mb-4">
        <label>Title <span class="mandatory">*</span></label>
        <input required type="text" name="title" value="<%= project.title || '' %>">
      </div>

      <div class="form-group mb-4">
        <label>Subtitle</label>
        <input type="text" name="subtitle" value="<%= project.subtitle || '' %>">
      </div>

      <label>
        Description <span class="mandatory">*</span>
      </label>

      <textarea class="w-100"
        required
        name="description"
        maxlength="1000"
        placeholder="Enter description..."
      ><%= project.description || '' %></textarea>

      <div class="char-counter" id="descriptionCounter">
        0 / 1000
      </div>

      <!-- TAGS -->
      <div class="tag-list">

        <% tags.forEach(tag => { %>
          <div class="tag-row">
            <label>
              <input 
                type="checkbox" 
                name="tags" 
                value="<%= tag.id %>"
                <%= projectTags.includes(tag.id) ? "checked" : "" %>
              >
              <span><%= tag.name %></span>
            </label>

            <a 
              href="/admin/tags/delete/<%= tag.id %>?slug=<%= project.slug %>" 
              class="tag-delete"
              onclick="return confirm('Delete this tag permanently?')"
            >
              ✕
            </a>
          </div>
        <% }) %>

        <div class="tag-add">
          <button type="button" id="showTagInput">+ New tag</button>

          <div id="newTagWrapper" style="display:none; gap:8px; margin-top:8px;">
            <input 
              type="text" 
              id="newTagInput" 
              placeholder="Enter tag..."
            >

            <button 
              type="button" 
              id="addTagBtn"
              class="save-button"
            >
              Add
            </button>
          </div>

          <input type="hidden" name="newTag" id="hiddenNewTag">
        </div>
      </div>

      <button data-submit class="save-button mt-3">
        <%= isNew ? 'Create project' : 'Save' %>
      </button>
    </form>
  </div>

  <!-- PROJECT ITEMS -->
  <% if (!isNew) { %>
    <div class="project-card">
      <h3>Project items</h3>
      <p>Manage the gallery items of the project here.</p>

      <div class="admin-table-wrapper">
        <table class="admin-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Image</th>
              <th>Main picture</th>
              <th>Order</th>
              <th>Layout</th>
              <th>Description</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>
            <% items.forEach((item, i) => { %>
              <tr 
                class="item-row"
                data-id="<%= item.id %>"
                data-image="<%= item['image-url'] || '/images/blank.png' %>"
                data-main="<%= item.is_main %>"
                data-order="<%= item.note_order %>"
                data-layout="<%= item.layout %>"
                data-description="<%= item.description %>"
              >
                <td><%= i + 1 %></td>

                <td>
                  <% if (item.layout && item.layout.includes('blank')) { %>
                    <img src="/images/blank.png">
                  <% } else { %>
                    <img src="<%= item['image-url'] %>">
                  <% } %>
                </td>

                <td>
                  <% if (item.is_main) { %>
                    <span class="checkmark">✓</span>
                  <% } else { %>
                    -
                  <% } %>
                </td>

                <td><%= item.note_order || '-' %></td>
                <td><%= item.layout || '-' %></td>
                <td><%= item.description || '-' %></td>

                <td>
                  <button 
                    type="button"
                    class="delete-item-btn"
                    data-delete
                    data-id="<%= item.id %>" 
                    data-type="item"
                  >
                    🗑️
                  </button>
                </td>
              </tr>
            <% }) %>

            <tr class="add-project-row">
              <td colspan="7" class="text-center">
                + Add new project item
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- MODAL -->
    <div class="admin-modal" id="itemModal">
      <div class="admin-modal-content">
        <span class="admin-modal-close">&times;</span>

        <h3>Edit item</h3>

        <form 
          class="js-validate-form" 
          id="itemForm" 
          method="POST" 
          enctype="multipart/form-data"
        >              
          <input type="hidden" name="itemId" id="modalItemId">

          <div class="form-group">
            <label>Image</label>

            <div class="image-upload">
              <img id="modalImage" src="" alt="">
              <input type="file" name="image" id="modalImageInput" accept="image/*">
            </div>
          </div>

          <div class="form-group">
            <label class="pe-2">Main picture</label>
            <input type="checkbox" name="is_main" id="modalMain">
          </div>

          <div class="form-group">
            <label class="pe-2">Order</label>
            <input required type="number" name="note_order" id="modalOrder">
          </div>

          <div class="form-group">
            <label class="pe-2">Layout</label>
            <select name="layout" id="modalLayout">
              <option value="square">Portrait</option>
              <option value="wide">Landscape</option>
              <option value="square-blank">Blank portrait</option>
              <option value="wide-blank">Blank landscape</option>
            </select>
          </div>

          <div class="form-group">
            <label class="pe-2">Description</label>
            <textarea name="description" id="modalDescription"></textarea>
          </div>

          <input type="hidden" name="projectId" value="<%= project.id %>">
          <input type="hidden" name="projectSlug" value="<%= project.slug %>">

          <button class="save-button mt-3">Save</button>
        </form>
      </div>
    </div>
  <% } %>

  <% if (message) { %>
    <div class="admin-toast <%= message.type %>" id="adminToast">
      <%= message.text %>
    </div>
  <% } %>

  <div class="admin-modal" id="deleteModal">
    <div class="admin-modal-content">
      <h3>Delete item</h3>
      <p>Are you sure you want to delete this item?</p>

      <div class="d-flex justify-content-between gap-2 mt-3">
        <button id="confirmDelete" type="button" class="save-button">Delete</button>
        <button id="cancelDelete" type="button">Cancel</button>
      </div>
    </div>
  </div>
</div>

<script>
  window.projectSlug = "<%= project.slug %>";
  console.log();
</script>