<div class="admin-container">
  <h1 class="mb-4">Landing editor</h1>

  <p class="mb-4">
    This page allows you to manage the main visual content of the website’s
    landing page.
  </p>

  <form class="js-validate-form" action="/admin/landing" method="POST" enctype="multipart/form-data">

    <!-- MAIN VIDEO -->
    <div class="project-card mb-4">
      <h3>Main video</h3>

      <!-- DESKTOP VIDEO -->
      <div class="form-group file-input-wrapper">
        <label>Upload main video (horizontal - desktop)<span class="mandatory">*</span></label>

        <% if (landing?.main_video_horizontal) { %>
          <div class="current-file">
            Current file:
            <strong><%= landing.main_video_horizontal.split('/').pop() %></strong>
          </div>
        <% } else { %>
          <div class="current-file">No file uploaded yet</div>
        <% } %>

        <div class="file-input-container d-flex justify-content-between">
          <input type="file" name="mainVideoHorizontal" accept="video/*" />
          <button type="button" class="clear-file">x</button>
        </div>
      </div>

      <!-- MOBILE VIDEO -->
      <div class="form-group file-input-wrapper">
        <label>Upload main video (vertical - phone)<span class="mandatory">*</span></label>

        <% if (landing?.main_video_vertical) { %>
          <div class="current-file">
            Current file:
            <strong><%= landing.main_video_vertical.split('/').pop() %></strong>
          </div>
        <% } else { %>
          <div class="current-file">No file uploaded yet</div>
        <% } %>

        <div class="file-input-container d-flex justify-content-between">
          <input type="file" name="mainVideoVertical" accept="video/*" />
          <button type="button" class="clear-file">x</button>
        </div>
      </div>
    </div>

    <!-- ABOUT SECTION -->
    <div class="project-card mb-4">
      <h3>About section</h3>

      <!-- SMALL IMAGE -->
      <div class="form-group">
        <label>Small image <span class="mandatory">*</span></label>

        <% if (landing?.about_image_small) { %>
          <div class="current-file">
            Current file:
            <strong><%= landing.about_image_small.split('/').pop() %></strong>
          </div>
        <% } else { %>
          <div class="current-file">No file uploaded yet</div>
        <% } %>

        <div class="file-input-container d-flex justify-content-between">
          <input type="file" name="aboutImageSmall" accept="image/*" />
          <button type="button" class="clear-file">x</button>
        </div>
      </div>

      <!-- LARGE IMAGE -->
      <div class="form-group">
        <label>Large image <span class="mandatory">*</span></label>

        <% if (landing?.about_image_large) { %>
          <div class="current-file">
            Current file:
            <strong><%= landing.about_image_large.split('/').pop() %></strong>
          </div>
        <% } else { %>
          <div class="current-file">No file uploaded yet</div>
        <% } %>

        <div class="file-input-container d-flex justify-content-between">
          <input type="file" name="aboutImageLarge" accept="image/*" />
          <button type="button" class="clear-file">x</button>
        </div>
      </div>

      <!-- GIF -->
      <div class="form-group">
        <label>Upload gif <span class="mandatory">*</span></label>

        <% if (landing?.about_video) { %>
          <div class="current-file">
            Current file:
            <strong><%= landing.about_video.split('/').pop() %></strong>
          </div>
        <% } else { %>
          <div class="current-file">No file uploaded yet</div>
        <% } %>

        <div class="file-input-container d-flex justify-content-between">
          <input type="file" name="aboutVideo" accept="image/gif" />
          <button type="button" class="clear-file">x</button>
        </div>
      </div>

      <!-- DESCRIPTION -->
      <div class="form-group">
        <label>About description <span class="mandatory">*</span></label>
        <textarea 
          name="description"
          maxlength="800"
          placeholder="Enter description..."
        ><%= landing?.about_description || "" %></textarea>
      </div>
    </div>

    <button data-submit class="save-button" id="saveBtn" disabled>Save changes</button>
  </form>

  <% if (message) { %>
    <div class="admin-toast <%= message.type %>" id="adminToast">
      <%= message.text %>
    </div>
  <% } %>
</div>